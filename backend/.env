# ─────────────────────────────────────────────────────────────
#  StudioYield Backend — Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000

# PostgreSQL — local example: postgresql://postgres:password@localhost:5432/studioyield
# Cloud (Neon/Supabase/Railway): paste your full connection string here
DATABASE_URL=postgresql://postgres:imapanaas25@db.tdfznyzoxfkcyupevazf.supabase.co:5432/postgres

# JWT — generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=9c187b1ede5c102b4f3dedbb70279e9706cab387acf4c2e784ff598041e074502b841edf9c5d5c07b3637d5260b77a331ec8ebda8d19c786380b7d110e90570f
JWT_EXPIRES_IN=24h
JWT_REMEMBER_EXPIRES_IN=7d

# NodeMailer SMTP — leave blank to disable email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# From address shown in notification emails
MAIL_FROM="StudioYield <noreply@studioyield.app>"

# Frontend URL (for CORS allow-list)
CLIENT_URL=https://job-schedule-optimization.vercel.app
